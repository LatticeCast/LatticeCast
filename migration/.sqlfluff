[sqlfluff]
dialect = postgres
max_line_length = 140

# Exclusions tuned for the v40 squash baseline (V1-V14):
# RF04 — keywords as column names (`name`, `role`, `user`) is deliberate; PG allows it.
# LT01 — whitespace-before-keyword fires on the squash's hand-aligned column blocks
#        inside CREATE TABLE and on multi-line GRANT statements; alignment is readable
#        but doesn't match SQLFluff's single-space heuristic in every context.
# LT02 — line indent fires on continuation lines inside multi-line GRANT/SELECT/INSERT
#        bodies that are indented for scanability. Flushing them left hurts readability.
# These rules can't fix-pass the locked V1-V14 set without editing those files. The
# baseline is locked (no checksum changes after launch), so we relax the lint config.
exclude_rules = references.keywords, layout.spacing, layout.indent

[sqlfluff:rules:layout.long_lines]
max_line_length = 140
