# .env.example
DEBUG_MODE=1
AUTH_REQUIRED=false

# Single public-facing port — nginx (lattice-cast service) terminates here
# and proxies /api/* → backend, /* → frontend. There's no separate FE/BE
# port to expose.
NGX_PORT=13491

# ── E2E target — single knob to point tests at any environment ──────────
# Leave unset → tests hit the local stack at http://localhost:${NGX_PORT}.
# Set to a deployed URL to run the same e2e scripts against staging/prod.
#E2E_BASE_URL=https://lattice-cast.posetmage.com
#E2E_BROWSER_WS=ws://localhost:4444


# DB (DBA creds are in docker-compose.yml only, not here)
POSTGRES_DB=db
POSTGRES_URL=db:5432

# App — general API (CRUD public, SELECT auth) → app_user
POSTGRES_APP_PASSWORD=app_pws

# Manager — login/admin paths, BYPASSRLS → mgr_user
POSTGRES_MGR_PASSWORD=mgr_pws

AUTHENTIK_URL="https://authentik.example.com"
AUTHENTIK_CLIENT_ID="authentik_client_id"

# Google OAuth - Get credentials from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-secret"

SAMPLE_USER=aaaaa
SAMPLE_PASSWORD=aaaaaPSWD

# MinIO S3-compatible storage
MINIO_ROOT_USER=_minio_user
MINIO_ROOT_PASSWORD=_minio_password
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=_minio_user
MINIO_SECRET_KEY=_minio_password
MINIO_BUCKET=lattice-cast
