# .env.example
DEBUG_MODE=1
AUTH_REQUIRED=false

FRONTEND_PORT=13492

# be
BACKEND_PORT=13491


# db
POSTGRES_USER=usr
POSTGRES_PASSWORD=pws
POSTGRES_DB=db
POSTGRES_DBA_PASSWORD=dba_password
POSTGRES_APP_PASSWORD=app_password
POSTGRES_LOGIN_PASSWORD=login_password

# Replace with  DB credentials!
DATABASE_URL="postgres://usr:pws@postgres:5432/db"

AUTHENTIK_URL="https://authentik.example.com"
AUTHENTIK_CLIENT_ID="authentik_client_id"

# Google OAuth - Get credentials from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-secret"

SAMPLE_USER=aaaaa
SAMPLE_PASSWORD=aaaaaPSWD

# MinIO S3-compatible storage
MINIO_ROOT_USER=_minio_user
MINIO_ROOT_PASSWORD=_minio_password
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=_minio_user
MINIO_SECRET_KEY=_minio_password
MINIO_BUCKET=lattice-cast
