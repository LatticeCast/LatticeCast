# .env.example
DEBUG_MODE=1
AUTH_REQUIRED=false

FRONTEND_PORT=13492

# be
BACKEND_PORT=13491


# DB shared
POSTGRES_DB=db
POSTGRES_URL=postgres:5432

# db container init + healthcheck only (NOT used by app code)
POSTGRES_USER=usr
POSTGRES_PASSWORD=pws

# DBA — migrations (DDL + DML on all schemas) → login user: dba_user
POSTGRES_DBA_PASSWORD=dba_pws

# App — general API (CRUD public schema, SELECT auth schema) → login user: app_user
POSTGRES_APP_PASSWORD=app_pws

# Login manager — auth endpoints (CRUD auth schema only) → login user: login_user
POSTGRES_LOGIN_PASSWORD=login_pws

AUTHENTIK_URL="https://authentik.example.com"
AUTHENTIK_CLIENT_ID="authentik_client_id"

# Google OAuth - Get credentials from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-secret"

SAMPLE_USER=aaaaa
SAMPLE_PASSWORD=aaaaaPSWD

# MinIO S3-compatible storage
MINIO_ROOT_USER=_minio_user
MINIO_ROOT_PASSWORD=_minio_password
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=_minio_user
MINIO_SECRET_KEY=_minio_password
MINIO_BUCKET=lattice-cast
